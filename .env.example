# Required by local and Docker finder-gateway.
FINDER_API_KEY=change_me_to_a_long_random_key

FINDER_PAGE_URL=https://channels.weixin.qq.com/platform/
FINDER_BROWSER_HEADLESS=false
FINDER_PROFILE_DIR=./data/chromium-profile
FINDER_REQUEST_TIMEOUT=25
FINDER_STARTUP_TIMEOUT=45

# Used by Docker Compose. Local scripts accept -Port parameters.
FINDER_GATEWAY_PORT=8790
FINDER_NOVNC_PORT=6080

# Required only by the optional Docker/noVNC deployment.
FINDER_VNC_PASSWORD=change_me_to_a_strong_password

# Optional wxsph profile.
WXSPH_API_KEYS=change_me_to_a_long_random_key
WXSPH_COOKIE=
# WXSPH_COOKIES=cookie_a||cookie_b
WXSPH_TIMEOUT=18
WXSPH_DEBUG=false
WXSPH_RATE_LIMIT_PER_MIN=30
WXSPH_CACHE_TTL=600
WXSPH_TRUST_PROXY=true
WXSPH_HOST_PORT=8787
